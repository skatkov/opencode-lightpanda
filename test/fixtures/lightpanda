#!/usr/bin/env bun

const args = process.argv.slice(2)
const url = new URL(args[1])

if (url.pathname === "/malformed") {
  process.stdout.write("{")
} else if (url.pathname === "/oversized") {
  process.stdout.write("x".repeat(5 * 1024 * 1024 + 1))
} else if (url.pathname === "/slow") {
  await Bun.sleep(10_000)
} else {
  process.stdout.write(
    JSON.stringify({
      url: url.href,
      http_status: url.pathname === "/not-found" ? 404 : 200,
      headers: [{ name: "Content-Type", value: "text/plain" }],
      content: url.pathname === "/command" ? JSON.stringify(args) : "fixture content",
    }),
  )
}
